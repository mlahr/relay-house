ADDR=:8080
DATABASE_PATH=relay-house.db
DELIVERY_PROVIDER=smtp

PROJECT_KEY=replace-with-public-project-key
PROJECT_NAME=main
ALLOWED_ORIGINS=https://example.com,https://www.example.com
RECIPIENTS=you@example.com

MAIL_FROM=Website Contact <contact@example.com>

# SMTP provider config. Required when DELIVERY_PROVIDER=smtp.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=smtp-password

# Mailtrap REST API provider config. Required when DELIVERY_PROVIDER=mailtrap.
MAILTRAP_API_URL=https://send.api.mailtrap.io/api/send
MAILTRAP_API_TOKEN=
MAILTRAP_BCC=

# Optional. If set, every request must include a valid Cloudflare Turnstile token.
TURNSTILE_SECRET=

RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_PER_DAY=100
MAX_RETRIES=5
WORKER_INTERVAL_SECONDS=5
RETENTION_DAYS=365
IP_HASH_SECRET=replace-with-random-secret
